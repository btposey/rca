# Anthropic API (teacher model for distillation + dataset generation)
ANTHROPIC_API_KEY=

# PostgreSQL (localhost within pod)
DATABASE_URL=postgresql+asyncpg://rca:rca@localhost:5432/rca

# vLLM endpoints (localhost within pod)
VLLM_DISPATCHER_BASE_URL=http://localhost:8000/v1
VLLM_DISPATCHER_MODEL=dispatcher-llama-1b
VLLM_CONCIERGE_BASE_URL=http://localhost:8001/v1
VLLM_CONCIERGE_MODEL=concierge-llama-3b

# HuggingFace
HF_HOME=/models
HUGGING_FACE_HUB_TOKEN=
